<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- ======================== TYPOGRAPHY ======================== -->

    <Style x:Key="PageTitle" TargetType="Label">
        <Setter Property="FontFamily" Value="DMSans" />
        <Setter Property="FontSize" Value="26" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
    </Style>

    <Style x:Key="SectionLabel" TargetType="Label">
        <Setter Property="FontFamily" Value="DMSans" />
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
    </Style>

    <Style x:Key="BodyText" TargetType="Label">
        <Setter Property="FontFamily" Value="DMSans" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="LineBreakMode" Value="WordWrap" />
    </Style>

    <Style x:Key="SerifText" TargetType="Label">
        <Setter Property="FontFamily" Value="SourceSerif4" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="LineBreakMode" Value="WordWrap" />
        <Setter Property="LineHeight" Value="1.6" />
    </Style>

    <Style x:Key="MutedText" TargetType="Label">
        <Setter Property="FontFamily" Value="DMSans" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="TextColor" Value="{StaticResource TextMuted}" />
    </Style>

    <Style x:Key="CaptionText" TargetType="Label">
        <Setter Property="FontFamily" Value="DMSans" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="TextColor" Value="{StaticResource TextMuted}" />
    </Style>

    <!-- ======================== CARDS ======================== -->

    <Style x:Key="CardFrame" TargetType="Frame">
        <Setter Property="BackgroundColor" Value="{StaticResource BgSurface}" />
        <Setter Property="BorderColor" Value="{StaticResource BorderLight}" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="HasShadow" Value="True" />
    </Style>

    <Style x:Key="LiveCardFrame" TargetType="Frame">
        <Setter Property="BackgroundColor" Value="{StaticResource SuccessLight}" />
        <Setter Property="BorderColor" Value="{StaticResource Success}" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="HasShadow" Value="True" />
    </Style>

    <Style x:Key="HubCardFrame" TargetType="Frame">
        <Setter Property="BackgroundColor" Value="{StaticResource BgSurface}" />
        <Setter Property="BorderColor" Value="{StaticResource BorderLight}" />
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="Padding" Value="20,16" />
        <Setter Property="HasShadow" Value="True" />
    </Style>

    <!-- ======================== BUTTONS ======================== -->

    <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource Accent}" />
        <Setter Property="TextColor" Value="{StaticResource TextOnAccent}" />
        <Setter Property="FontFamily" Value="DMSans" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="16,10" />
        <Setter Property="MinimumHeightRequest" Value="44" />
    </Style>

    <Style x:Key="SuccessButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource Success}" />
        <Setter Property="TextColor" Value="{StaticResource TextOnAccent}" />
        <Setter Property="FontFamily" Value="DMSans" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="16,10" />
        <Setter Property="MinimumHeightRequest" Value="44" />
    </Style>

    <Style x:Key="DangerButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource Danger}" />
        <Setter Property="TextColor" Value="{StaticResource TextOnAccent}" />
        <Setter Property="FontFamily" Value="DMSans" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="16,10" />
        <Setter Property="MinimumHeightRequest" Value="44" />
    </Style>

    <Style x:Key="OutlineButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="TextColor" Value="{StaticResource Accent}" />
        <Setter Property="BorderColor" Value="{StaticResource Accent}" />
        <Setter Property="BorderWidth" Value="1.5" />
        <Setter Property="FontFamily" Value="DMSans" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="16,10" />
        <Setter Property="MinimumHeightRequest" Value="44" />
    </Style>

    <!-- ======================== LINK LABELS ======================== -->

    <Style x:Key="LinkLabel" TargetType="Label">
        <Setter Property="FontFamily" Value="DMSans" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="TextColor" Value="{StaticResource Accent}" />
        <Setter Property="TextDecorations" Value="Underline" />
    </Style>

    <!-- ======================== PAGE CONTAINER ======================== -->

    <Style x:Key="PageScrollView" TargetType="ScrollView">
        <Setter Property="BackgroundColor" Value="{StaticResource BgPrimary}" />
    </Style>

    <Style x:Key="ContentPage" TargetType="ContentPage">
        <Setter Property="BackgroundColor" Value="{StaticResource BgPrimary}" />
    </Style>

</ResourceDictionary>
