<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:SoPorHoje.App.ViewModels"
             x:Class="SoPorHoje.App.Views.PrayersPage"
             x:DataType="vm:PrayersViewModel"
             Title="Orações"
             BackgroundColor="{StaticResource BgPrimary}"
             SemanticProperties.Description="Orações de Alcoólicos Anônimos">

    <ScrollView Style="{StaticResource PageScrollView}">
        <VerticalStackLayout Padding="16,12,16,32" Spacing="0">

            <!-- Header -->
            <Label Text="Orações"
                   Style="{StaticResource PageTitle}"
                   Margin="0,4,0,4"
                   SemanticProperties.HeadingLevel="Level1"
                   SemanticProperties.Description="Orações de A.A." />
            <Label Text="As orações que acompanham a jornada de recuperação"
                   Style="{StaticResource MutedText}"
                   Margin="0,0,0,20"
                   SemanticProperties.Description="As orações que acompanham a jornada de recuperação" />

            <!-- Cards de Oração -->
            <CollectionView ItemsSource="{Binding Prayers}"
                            SelectionMode="None"
                            SemanticProperties.Description="Lista de orações">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:PrayerItem">
                        <Frame Style="{StaticResource CardFrame}"
                               Margin="0,0,0,16"
                               SemanticProperties.Description="{Binding Name, StringFormat='Oração: {0}'}">

                            <VerticalStackLayout Spacing="12">

                                <!-- Nome da oração -->
                                <Label Text="{Binding Name}"
                                       Style="{StaticResource SectionLabel}"
                                       TextColor="{StaticResource Warm}"
                                       SemanticProperties.HeadingLevel="Level2"
                                       SemanticProperties.Description="{Binding Name}" />

                                <!-- Texto da oração -->
                                <Label Text="{Binding Text}"
                                       Style="{StaticResource SerifText}"
                                       FontAttributes="Italic"
                                       SemanticProperties.Description="{Binding Text}" />

                                <!-- Botão copiar -->
                                <Button Text="📋  Copiar"
                                        Style="{StaticResource OutlineButton}"
                                        HorizontalOptions="End"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:PrayersViewModel}}, Path=CopyPrayerCommand}"
                                        CommandParameter="{Binding .}"
                                        SemanticProperties.Description="{Binding Name, StringFormat='Copiar oração {0} para a área de transferência'}" />

                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
