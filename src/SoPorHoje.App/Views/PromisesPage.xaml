<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:SoPorHoje.App.ViewModels"
             x:Class="SoPorHoje.App.Views.PromisesPage"
             x:DataType="vm:PromisesViewModel"
             Title="As Promessas"
             BackgroundColor="{StaticResource BgPrimary}"
             SemanticProperties.Description="As Promessas de Alcoólicos Anônimos">

    <ScrollView Style="{StaticResource PageScrollView}">
        <VerticalStackLayout Padding="16,12,16,32" Spacing="0">

            <!-- Header -->
            <Label Text="As Promessas"
                   Style="{StaticResource PageTitle}"
                   Margin="0,4,0,4"
                   SemanticProperties.HeadingLevel="Level1"
                   SemanticProperties.Description="As Promessas de A.A." />
            <Label Text="Se trabalharmos para isso, elas se materializarão."
                   Style="{StaticResource SerifText}"
                   FontAttributes="Italic"
                   Margin="0,0,0,20"
                   SemanticProperties.Description="Se trabalharmos para isso, elas se materializarão." />

            <!-- Lista de Promessas -->
            <CollectionView ItemsSource="{Binding Promises}"
                            SelectionMode="None"
                            SemanticProperties.Description="Lista das Promessas de A.A.">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="x:String">
                        <Frame CornerRadius="12"
                               Padding="0"
                               HasShadow="True"
                               Margin="0,0,0,10"
                               BorderColor="{StaticResource BorderLight}"
                               BackgroundColor="{StaticResource BgSurface}"
                               SemanticProperties.Description="{Binding .}">
                            <Grid ColumnDefinitions="6,*" ColumnSpacing="0">

                                <!-- Borda lateral dourada -->
                                <BoxView Grid.Column="0"
                                         BackgroundColor="{StaticResource Warm}"
                                         CornerRadius="12,0,12,0"
                                         SemanticProperties.Description="" />

                                <!-- Texto da promessa -->
                                <Label Grid.Column="1"
                                       Text="{Binding .}"
                                       Style="{StaticResource SerifText}"
                                       Padding="14,14,14,14"
                                       SemanticProperties.Description="{Binding .}" />
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
