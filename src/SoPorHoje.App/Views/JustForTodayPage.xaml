<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:SoPorHoje.App.ViewModels"
             x:Class="SoPorHoje.App.Views.JustForTodayPage"
             x:DataType="vm:JustForTodayViewModel"
             Title="Só Por Hoje"
             BackgroundColor="{StaticResource BgPrimary}"
             SemanticProperties.Description="Meditações Só Por Hoje">

    <ScrollView Style="{StaticResource PageScrollView}">
        <VerticalStackLayout Padding="16,12,16,32" Spacing="0">

            <!-- Header -->
            <Label Text="Só Por Hoje"
                   Style="{StaticResource PageTitle}"
                   Margin="0,4,0,4"
                   SemanticProperties.HeadingLevel="Level1"
                   SemanticProperties.Description="Meditações Só Por Hoje" />
            <Label Text="Nove meditações para viver um dia de cada vez"
                   Style="{StaticResource MutedText}"
                   Margin="0,0,0,20"
                   SemanticProperties.Description="Nove meditações para viver um dia de cada vez" />

            <!-- Cards de Meditação -->
            <CollectionView ItemsSource="{Binding Meditations}"
                            SelectionMode="None"
                            SemanticProperties.Description="Lista de meditações Só Por Hoje">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="x:String">
                        <Frame Style="{StaticResource CardFrame}"
                               Margin="0,0,0,12"
                               SemanticProperties.Description="{Binding .}">

                            <Label Text="{Binding .}"
                                   Style="{StaticResource SerifText}"
                                   FontAttributes="Italic"
                                   SemanticProperties.Description="{Binding .}" />

                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
