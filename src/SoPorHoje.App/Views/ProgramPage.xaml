<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:SoPorHoje.App.ViewModels"
             x:Class="SoPorHoje.App.Views.ProgramPage"
             x:DataType="vm:ProgramViewModel"
             Title="Programa"
             BackgroundColor="{StaticResource BgPrimary}"
             SemanticProperties.Description="Hub do Programa de A.A.">

    <ScrollView Style="{StaticResource PageScrollView}">
        <VerticalStackLayout Padding="16,12,16,32" Spacing="0">

            <!-- Header -->
            <Label Text="Programa"
                   Style="{StaticResource PageTitle}"
                   Margin="0,4,0,4"
                   SemanticProperties.HeadingLevel="Level1"
                   SemanticProperties.Description="Programa de A.A." />
            <Label Text="A literatura e ferramentas de recuperação"
                   Style="{StaticResource MutedText}"
                   Margin="0,0,0,20"
                   SemanticProperties.Description="A literatura e ferramentas de recuperação do A.A." />

            <!-- Seções do Programa -->
            <CollectionView ItemsSource="{Binding Sections}"
                            SelectionMode="None"
                            SemanticProperties.Description="Seções do programa">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:ProgramSection">
                        <Frame Style="{StaticResource HubCardFrame}"
                               Margin="0,0,0,12"
                               SemanticProperties.Description="{Binding Title, StringFormat='Seção {0}. Toque para abrir.'}">
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ProgramViewModel}}, Path=NavigateCommand}"
                                    CommandParameter="{Binding .}" />
                            </Frame.GestureRecognizers>

                            <Grid ColumnDefinitions="Auto,*,Auto"
                                  ColumnSpacing="16"
                                  MinimumHeightRequest="44">

                                <!-- Ícone -->
                                <Label Text="{Binding Icon}"
                                       FontSize="28"
                                       VerticalOptions="Center"
                                       SemanticProperties.Description="" />

                                <!-- Textos -->
                                <VerticalStackLayout Grid.Column="1"
                                                     Spacing="2"
                                                     VerticalOptions="Center">
                                    <Label Text="{Binding Title}"
                                           Style="{StaticResource SectionLabel}"
                                           SemanticProperties.HeadingLevel="Level2" />
                                    <Label Text="{Binding Description}"
                                           Style="{StaticResource MutedText}"
                                           SemanticProperties.Description="{Binding Description}" />
                                </VerticalStackLayout>

                                <!-- Chevron -->
                                <Label Grid.Column="2"
                                       Text="›"
                                       FontSize="22"
                                       TextColor="{StaticResource TextMuted}"
                                       VerticalOptions="Center"
                                       SemanticProperties.Description="" />
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
